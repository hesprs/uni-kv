{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"],
            "cache": true
		},
		"lint": {
            "dependsOn": [],
            "cache": true
        },
		"check": {
            "cache": true,
			"dependsOn": ["^build"]
		},
		"dev": {
            "dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		}
	}
}
